#!/usr/bin/env bash
# bin/mimir-redact-check
#
# Scans stdin for known secret patterns. Exits 0 if clean, 1 if any
# pattern matched. Used by Mimir's PreToolUse hook to refuse Write/Edit
# operations that would commit a secret to a tracked file.
#
# Bypass via env var (escape hatch for legitimate documentation):
#   MIMIR_REDACT_BYPASS=1
#
# Implementation note: uses perl, not grep. Earlier versions gated on
# `grep -P` availability, which is false on macOS BSD grep — that path
# silently degraded the pattern set. perl is universally available
# (macOS / Linux ship it; Claude Code containers include it). The
# pattern set must stay in lock-step with bin/mimir-redact.

set -u

# Bypass for legitimate cases (e.g. user explicitly documents an example key).
if [[ "${MIMIR_REDACT_BYPASS:-0}" == "1" ]]; then
  cat >/dev/null  # drain stdin
  exit 0
fi

if ! command -v perl >/dev/null 2>&1; then
  # If perl is missing the wrapper falls through too. Fail open
  # rather than block legitimate writes — but log a warning so the
  # missing dependency surfaces.
  echo "⚠️  Mimir warning: perl not found; secret-pattern check skipped." >&2
  cat >/dev/null
  exit 0
fi

# Each entry is "label||pattern". Patterns mirror bin/mimir-redact —
# keep them in sync. Delimiter `||` keeps labels human-readable in
# the failure message.
PATTERNS=(
  'aws-access-key||AKIA[0-9A-Z]{16}'
  'aws-secret||(?i)aws_secret_access_key["'\'':\s=]+[A-Za-z0-9/+=]{40}'
  'github-pat||ghp_[A-Za-z0-9]{36}'
  'github-oauth||gho_[A-Za-z0-9]{36}'
  'github-server||ghs_[A-Za-z0-9]{36}'
  'github-user-token||ghu_[A-Za-z0-9]{36}'
  'github-refresh-token||ghr_[A-Za-z0-9]{36}'
  'github-fine-grained||github_pat_[A-Za-z0-9_]{82}'
  'gitlab-pat||glpat-[A-Za-z0-9_-]{20,}'
  'slack-token||xox[baprs]-[A-Za-z0-9-]{10,}'
  'google-api-key||AIza[A-Za-z0-9_-]{35}'
  'anthropic||sk-ant-[A-Za-z0-9_-]{20,}'
  'openai||sk-(?:proj-)?[A-Za-z0-9_-]{32,}'
  'stripe-key||(?:sk|rk)_(?:live|test)_[A-Za-z0-9]{24,}'
  'npm-token||npm_[A-Za-z0-9]{36}'
  'sendgrid||SG\.[A-Za-z0-9_-]{22}\.[A-Za-z0-9_-]{43}'
  'twilio-sid||AC[0-9a-f]{32}'
  'twilio-api-key||SK[0-9a-f]{32}'
  'jwt||eyJ[A-Za-z0-9_-]+\.[A-Za-z0-9_-]+\.[A-Za-z0-9_-]+'
  'pem-private-key||-----BEGIN [A-Z ]+PRIVATE KEY-----'
  'bearer||(?i)bearer\s+[A-Za-z0-9._~+/-]{20,}'
  'basic-auth-url||https?://[^:/\s]+:[^@\s]{4,}@'
  'generic-token||(?i)(?:api[_-]?key|api[_-]?secret|access[_-]?token|auth[_-]?token|password|passwd|secret)["'\'':\s=]+["'\'']?[A-Za-z0-9._~+/-]{12,}'
)

content=$(cat)
if [[ -z "$content" ]]; then
  exit 0
fi

for entry in "${PATTERNS[@]}"; do
  label="${entry%%||*}"
  pattern="${entry#*||}"
  # Pass the pattern via env to avoid quoting hell and to keep perl's
  # regex delimiter (`m{...}`) free from collision with `/`, `!`,
  # `,` etc. that may appear in the pattern body.
  if printf '%s' "$content" | MIMIR_PAT="$pattern" perl -ne '
      BEGIN { $hit = 0; $pat = $ENV{MIMIR_PAT}; }
      $hit = 1 if /$pat/;
      END { exit ($hit ? 0 : 1) }
    '; then
    cat <<EOF >&2
🚫 Mimir refused: detected secret-like pattern (kind: $label)
   - Redact the value before retrying, or
   - Set MIMIR_REDACT_BYPASS=1 if this match is a legitimate false positive
     (e.g. documenting an example, not a real credential).
EOF
    exit 1
  fi
done

exit 0
